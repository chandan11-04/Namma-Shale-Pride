<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="@string/daily_meals"
            app:titleTextColor="@color/on_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- Already Uploaded Banner -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMealUploaded"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:visibility="gone"
                app:cardCornerRadius="@dimen/corner_md"
                app:cardBackgroundColor="#E8F5E9">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/meal_already_uploaded"
                    android:textColor="@color/primary_dark"
                    android:textStyle="bold"
                    android:padding="@dimen/spacing_md"
                    android:gravity="center"
                    android:textSize="@dimen/text_body" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Today's Meal Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTodayMeal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/corner_lg"
                app:cardElevation="@dimen/elevation_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/ivTodayMeal"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/image_meal_height"
                        android:scaleType="centerCrop"
                        android:contentDescription="Today meal" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/todays_meal"
                            android:textSize="@dimen/text_lg"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:id="@+id/tvTodayMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_body"
                            android:textColor="@color/on_surface_variant"
                            android:layout_marginTop="@dimen/spacing_xs" />

                        <TextView
                            android:id="@+id/tvTodayDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_sm"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="@dimen/spacing_xs" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- No Meal Today -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNoMeal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:visibility="gone"
                app:cardCornerRadius="@dimen/corner_lg">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/no_meal_today"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_md"
                    android:gravity="center"
                    android:padding="@dimen/spacing_xl" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Meal History Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/meal_history"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:layout_marginTop="@dimen/spacing_sm" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMealHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabUploadMeal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/spacing_md"
        android:src="@drawable/ic_camera"
        android:contentDescription="@string/upload_meal"
        android:visibility="gone"
        app:backgroundTint="@color/primary" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
