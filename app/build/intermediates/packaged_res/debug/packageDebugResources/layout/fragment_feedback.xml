<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="@string/feedback"
            app:titleTextColor="@color/on_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Parent: Send Feedback -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSendFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/corner_lg"
            app:cardElevation="@dimen/elevation_sm">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilFeedback"
                    style="@style/AppTextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/enter_feedback">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFeedback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="4"
                        android:gravity="top" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Voice Input Button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:layout_marginTop="4dp">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVoiceInput"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Speak"
                        app:icon="@android:drawable/ic_btn_speak_now"
                        android:textColor="@color/primary"
                        app:iconTint="@color/primary" />
                </LinearLayout>

                <!-- Anonymous Toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/anonymous_feedback"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:id="@+id/tvAnonymousHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/identity_visible"
                            android:textSize="@dimen/text_sm"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchAnonymous"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitFeedback"
                    style="@style/PrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/send_feedback"
                    android:layout_marginTop="@dimen/spacing_md" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Admin: Feedback List -->
        <TextView
            android:id="@+id/tvFeedbackHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recent_feedback"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_sm"
            android:visibility="gone" />

        <!-- Sentiment Summary Card for Admin -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSentimentSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#F8F9FA"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Overall Sentiment:"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvSentimentPositive"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🟢 0"
                    android:textSize="13sp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvSentimentNeutral"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🟡 0"
                    android:textSize="13sp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvSentimentNegative"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔴 0"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFeedback"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:padding="@dimen/spacing_md"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvNoFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_feedback"
            android:textColor="@color/text_hint"
            android:textSize="@dimen/text_md"
            android:gravity="center"
            android:padding="@dimen/spacing_xxl"
            android:visibility="gone" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
