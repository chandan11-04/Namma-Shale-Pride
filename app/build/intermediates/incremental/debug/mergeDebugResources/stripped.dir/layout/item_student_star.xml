<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_sm"
    app:cardCornerRadius="@dimen/corner_lg"
    app:cardElevation="@dimen/elevation_sm">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_md">

        <!-- Star accent bar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="@color/star_gold"
            android:layout_marginBottom="@dimen/spacing_md"
            android:layout_marginStart="-16dp"
            android:layout_marginEnd="-16dp"
            android:layout_marginTop="-16dp" />

        <ImageView
            android:id="@+id/ivStudentPhoto"
            android:layout_width="@dimen/avatar_large"
            android:layout_height="@dimen/avatar_large"
            android:scaleType="centerCrop"
            android:contentDescription="Student photo" />

        <TextView
            android:id="@+id/tvStudentName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_md"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:layout_marginTop="@dimen/spacing_sm" />

        <TextView
            android:id="@+id/tvClassName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge"
            android:textColor="@color/on_primary"
            android:textSize="@dimen/text_xs"
            android:layout_marginTop="@dimen/spacing_xs"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />

        <TextView
            android:id="@+id/tvAchievement"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/on_surface_variant"
            android:gravity="center"
            android:layout_marginTop="@dimen/spacing_sm"
            android:maxLines="3" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
