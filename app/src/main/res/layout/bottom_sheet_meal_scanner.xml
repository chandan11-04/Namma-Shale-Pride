<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/surface">

    <!-- Handle Bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#CCCCCC"
        android:layout_marginBottom="20dp" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🤖 AI Meal Quality Scan"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/on_surface"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvScanSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Analyzing nutritional content..."
        android:textSize="13sp"
        android:textColor="@color/text_hint"
        android:layout_marginBottom="20dp" />

    <!-- Scanning State -->
    <LinearLayout
        android:id="@+id/layoutScanning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <ProgressBar
            android:id="@+id/progressScan"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scanning meal image..."
            android:textSize="13sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="12dp" />
    </LinearLayout>

    <!-- Result State -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#F1FFF6"
        app:strokeColor="#4CAF50"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Status Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="✅"
                    android:textSize="24sp"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/tvNutritionStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nutritious &amp; Balanced"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D32" />

                    <TextView
                        android:id="@+id/tvNutritionDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#4CAF50"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCEECC"
                android:layout_marginBottom="12dp" />

            <!-- Detected Items -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍 Identified Items:"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvDetectedItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/on_surface_variant"
                android:layout_marginBottom="12dp" />

            <!-- Nutrition Chips Row -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupNutrition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleLine="false" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Done Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnScanDone"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Done"
        android:textAllCaps="false"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

</LinearLayout>
