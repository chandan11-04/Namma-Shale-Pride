<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="@string/admin_dashboard"
            app:titleTextColor="@color/on_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- Stats Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_md">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    app:cardCornerRadius="@dimen/corner_md"
                    app:cardBackgroundColor="#FFF3E0">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/spacing_md">
                        <TextView
                            android:id="@+id/tvMealCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="@dimen/text_xxl"
                            android:textStyle="bold"
                            android:textColor="#E65100" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/total_meals"
                            android:textSize="@dimen/text_sm"
                            android:textColor="#E65100" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_xs"
                    app:cardCornerRadius="@dimen/corner_md"
                    app:cardBackgroundColor="#E3F2FD">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/spacing_md">
                        <TextView
                            android:id="@+id/tvPostCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="@dimen/text_xxl"
                            android:textStyle="bold"
                            android:textColor="#1565C0" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/total_activities"
                            android:textSize="@dimen/text_sm"
                            android:textColor="#1565C0" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_lg">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    app:cardCornerRadius="@dimen/corner_md"
                    app:cardBackgroundColor="#FFFDE7">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/spacing_md">
                        <TextView
                            android:id="@+id/tvStarCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="@dimen/text_xxl"
                            android:textStyle="bold"
                            android:textColor="#F9A825" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/total_students"
                            android:textSize="@dimen/text_sm"
                            android:textColor="#F9A825" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_xs"
                    app:cardCornerRadius="@dimen/corner_md"
                    app:cardBackgroundColor="#F3E5F5">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/spacing_md">
                        <TextView
                            android:id="@+id/tvFeedbackCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="@dimen/text_xxl"
                            android:textStyle="bold"
                            android:textColor="#7B1FA2" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/total_feedback"
                            android:textSize="@dimen/text_sm"
                            android:textColor="#7B1FA2" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Action Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUploadMeal"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/upload_todays_meal"
                android:textAllCaps="false"
                app:icon="@drawable/ic_camera"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddPost"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/add_activity_post"
                android:textAllCaps="false"
                app:icon="@drawable/ic_home"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddStar"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/add_student_star"
                android:textAllCaps="false"
                app:icon="@drawable/ic_star"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManageFacilities"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/manage_facilities"
                android:textAllCaps="false"
                app:icon="@drawable/ic_facility"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewFeedback"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/feedback"
                android:textAllCaps="false"
                app:icon="@drawable/ic_feedback"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerateReport"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📄 Generate Report"
                android:textAllCaps="false"
                android:textColor="#1E6B3C"
                app:iconTint="#1E6B3C"
                app:backgroundTint="#E8F5E9"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <!-- Settings link -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettings"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings"
                android:textAllCaps="false"
                app:icon="@drawable/ic_settings"
                android:layout_marginTop="@dimen/spacing_md" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
